### ONE Data Commons — Local development ###

### API keys ###

DC_API_KEY=<YOUR_DC_API_KEY>
MAPS_API_KEY=<YOUR_MAPS_API_KEY>

### Data directories ###

# Absolute local paths — mounted into the Docker container.
# Default: custom_dc/sample (upstream example data) and custom_dc/sample_output.
INPUT_DIR=<ABSOLUTE_PATH>/custom_dc/sample
OUTPUT_DIR=<ABSOLUTE_PATH>/custom_dc/sample_output

### Application settings ###

FLASK_ENV=one
ENABLE_MODEL=true
GOOGLE_CLOUD_PROJECT=one-data-commons

### Docker images ###

DC_RELEASE=stable

### Database ###

# Local dev uses SQLite by default.
# Uncomment below to connect to Cloud SQL instead.
USE_SQLITE=true
USE_CLOUDSQL=false
#CLOUDSQL_INSTANCE=one-data-commons:northamerica-northeast1:kg-staging
#DB_NAME=datacommons
#DB_USER=datacommons
#DB_PASS=<YOUR_DB_PASS>
